# Telegram — get these from BotFather + /getUpdates
TELEGRAM_BOT_TOKEN=BotToken
TELEGRAM_CHAT_ID=ChatID

# Logging — valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=DEBUG

# n8n admin login
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# n8n webhook URL for triggering the pipeline on-demand from Telegram
N8N_WEBHOOK_URL=http://n8n:5678/webhook/trigger-digest

# LLM provider selection — which backend main.py builds at startup.
# Valid values: gemini, gemma. Defaults to gemma when unset.
LLM_PROVIDER=gemma

# Gemini (Google) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# OpenRouter (Gemma 4 31B free) — https://openrouter.ai/keys
# Model: google/gemma-4-31b-it:free
OPENROUTER_API_KEY=
